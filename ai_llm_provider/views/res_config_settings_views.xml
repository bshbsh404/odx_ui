<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_odx" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ai.llm.provider</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="ODX AI" string="ODX AI" name="odx_ai_settings"
                     logo="/ai_llm_provider/static/description/icon.png">

                    <block title="AI Providers" name="ai_providers_setting_container">
                        <setting id="ai_providers_setting">
                            <div class="w-50">
                                <field name="ai_provider_count" class="w-auto ps-1 fw-bold"/>
                                <span class="o_form_label" invisible="ai_provider_count > 1">
                                    AI Provider
                                </span>
                                <span class="o_form_label" invisible="ai_provider_count &lt;= 1">
                                    AI Providers
                                </span>
                            </div>
                            <div class="mt8">
                                <button name="%(ai_llm_provider.ai_llm_provider_action)d"
                                        icon="oi-arrow-right"
                                        type="action"
                                        string="Manage AI Providers"
                                        class="btn-link"/>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
