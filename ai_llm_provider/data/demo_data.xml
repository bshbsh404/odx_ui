<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Activate OpenAI provider for demo -->
        <record id="ai_llm_provider.provider_openai" model="ai.llm.provider">
            <field name="is_active" eval="True"/>
        </record>

        <!-- Demo chat models for OpenAI -->
        <record id="model_gpt4o" model="ai.llm.model">
            <field name="name">GPT-4o</field>
            <field name="model_id">gpt-4o</field>
            <field name="provider_id" ref="ai_llm_provider.provider_openai"/>
            <field name="purpose">chat</field>
            <field name="is_default" eval="True"/>
            <field name="max_tokens">4096</field>
            <field name="supports_tools" eval="True"/>
            <field name="supports_vision" eval="True"/>
            <field name="sequence">10</field>
        </record>

        <record id="model_gpt4o_mini" model="ai.llm.model">
            <field name="name">GPT-4o Mini</field>
            <field name="model_id">gpt-4o-mini</field>
            <field name="provider_id" ref="ai_llm_provider.provider_openai"/>
            <field name="purpose">chat</field>
            <field name="max_tokens">4096</field>
            <field name="supports_tools" eval="True"/>
            <field name="supports_vision" eval="True"/>
            <field name="sequence">20</field>
        </record>

        <!-- Demo embedding model -->
        <record id="model_embedding" model="ai.llm.model">
            <field name="name">Text Embedding 3 Small</field>
            <field name="model_id">text-embedding-3-small</field>
            <field name="provider_id" ref="ai_llm_provider.provider_openai"/>
            <field name="purpose">embedding</field>
            <field name="is_default" eval="True"/>
            <field name="sequence">30</field>
        </record>

    </data>
</odoo>
